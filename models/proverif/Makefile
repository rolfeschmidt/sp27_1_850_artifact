	./run.sh pqxdh-model-anonymity UnbreakableKEM CompromiseIK

anonymity-broken-kem-compromise-ik:
	./run.sh pqxdh-model-anonymity CompromiseIK

anonymity-broken-dh:
	./run.sh pqxdh-model-anonymity UnbreakableKEM BrokenDH

clean:
	rm *.gen.pv -f 


