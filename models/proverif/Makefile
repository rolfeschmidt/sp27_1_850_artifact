default:
	./run.sh pqxdh-model SecrecyInit SecrecyResp Authentication

test:
	./run.sh pqxdh-model SecrecyInit 

reach:
	./run.sh pqxdh-model Reach

anonymity:
	./run.sh pqxdh-model-anonymity UnbreakableKEM

